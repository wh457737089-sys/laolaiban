<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:gravity="center" android:orientation="vertical"
    android:padding="32dp" android:background="#faf9f6">

    <TextView android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="\uD83D\uDCED \u94F6\u9F84\u6570\u5B57\u751F\u6D3B\u52A9\u624B"
        android:textSize="32sp" android:textColor="#0d4827"
        android:textStyle="bold" android:gravity="center" />

    <TextView android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="\u5728\u5176\u4ED6APP\u4E0A\u65B9\u663E\u793A\u60AC\u6D6E\u5F15\u5BFC\uFF0C\u8BED\u97F3\u544A\u8BC9\u60A8\u6BCF\u4E00\u6B65\u600E\u4E48\u505A"
        android:textSize="18sp" android:textColor="#666"
        android:gravity="center" android:layout_marginTop="12dp"
        android:lineSpacingExtra="4dp" />

    <Button android:id="@+id/btnStart"
        android:layout_width="match_parent" android:layout_height="60dp"
        android:layout_marginTop="24dp" android:backgroundTint="#e65100"
        android:text="\uD83D\uDD0A \u5F00\u59CB\u5F15\u5BFC"
        android:textSize="22sp" android:textColor="#fff" />

    <TextView android:id="@+id/tipText"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="\u70B9\u51FB\u201C\u5F00\u59CB\u5F15\u5BFC\u201D\u540E\uFF0C\u8BF7\u5141\u8BB8\u60AC\u6D6E\u7A97\u6743\u9650\uFF0C\u7136\u540E\u60AC\u6D6E\u7403\u5C06\u663E\u793A\u5728\u6240\u6709APP\u4E0A\u65B9"
        android:textSize="16sp" android:textColor="#999"
        android:gravity="center" android:layout_marginTop="24dp"
        android:lineSpacingExtra="4dp" />

    <TextView
        android:id="@+id/privacyLink"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="隐私政策"
        android:textSize="16sp"
        android:textColor="#1a6b3c"
        android:autoLink="web"
        android:linksClickable="true"
        android:layout_marginTop="16dp" />

</LinearLayout>
